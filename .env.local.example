# Copy to .env.local and fill from Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# --- Email notifications (optional) ---------------------------------------
# Service-role key (Project Settings -> API -> service_role). SERVER ONLY —
# never expose to the browser. Used to look up CEO/HR emails to notify.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend API key (https://resend.com -> API Keys) and the verified From address.
RESEND_API_KEY=re_your_api_key
EMAIL_FROM="Pay Recommendations <noreply@yourdomain.com>"

# Public base URL of the deployed app, used to build "View recommendation"
# links in emails (e.g. https://your-app.vercel.app). No trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000
